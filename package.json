{
  "name": "learning-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Learning Tracker monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=backend",
    "dev:client": "npm run dev --workspace=frontend",
    "dev": "concurrently -n backend,frontend -c blue,green npm:dev:server npm:dev:client",
    "install:server": "npm install --workspace=backend",
    "install:client": "npm install --workspace=frontend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
