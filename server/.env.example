# Copy to server/.env for local development. Set the same keys on Render.
# Put real secrets only in server/.env — never commit that file.

PORT=5001
NODE_ENV=development
# Atlas (mongodb+srv://...) or local: mongodb://localhost:27017/learning-tracker
MONGO_URI=mongodb://localhost:27017/learning-tracker
JWT_SECRET=your-long-random-secret

# Gmail app password for daily reminder + issue report emails
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-gmail-app-password

# IANA timezone for reminder scheduling — all of India (incl. Telangana) uses Asia/Kolkata (IST)
REMINDER_TIMEZONE=Asia/Kolkata

# Secret for POST /api/cron/reminders (use with Render Cron or cron-job.org every minute)
CRON_SECRET=your-long-random-cron-secret

# Local dev only — run internal minute scheduler (production uses Render Cron)
# USE_INTERNAL_CRON=true

# Must match Vercel VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# Production frontend URL(s) for CORS (comma-separated if multiple)
FRONTEND_URL=https://learning-tracker-two-xi.vercel.app

# Admin inbox for issue reports (defaults to EMAIL_USER if unset)
ADMIN_EMAIL=admin@example.com
