# Copy to server/.env for local development. Set the same keys on Render.

PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/learning-tracker
JWT_SECRET=your-long-random-secret

# Gmail app password for daily reminder emails
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-gmail-app-password

# Must match Vercel VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# Production frontend URL for CORS (comma-separated if multiple)
FRONTEND_URL=http://localhost:5173
