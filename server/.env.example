# Copy to server/.env for local development. Set the same keys on Render.
# Put real secrets only in server/.env — never commit that file.

PORT=5001
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/learning-tracker
JWT_SECRET=your-long-random-secret

# Phone OTP — set OTP_MOCK=true locally (OTP printed in server logs)
OTP_MOCK=true
# MSG91_AUTH_KEY=your-msg91-key
# MSG91_SENDER_ID=LTTRCK

# Email reminders (Resend — https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Learning Tracker <onboarding@resend.dev>

REMINDER_TIMEZONE=Asia/Kolkata
CRON_SECRET=your-long-random-cron-secret

FRONTEND_URL=https://learning-tracker-two-xi.vercel.app

# Admin access: match reminder email or phone
ADMIN_EMAIL=admin@example.com
# ADMIN_PHONE=+919876543210
