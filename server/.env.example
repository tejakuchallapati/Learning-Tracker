# Copy to server/.env for local development. Set the same keys on Render.
# Put real secrets only in server/.env — never commit that file.

PORT=5001
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/learning-tracker
JWT_SECRET=your-long-random-secret

# Brevo — login OTP + reminders (https://app.brevo.com → SMTP & API → API keys)
# BREVO_API_KEY=xkeysib-xxxxxxxx
# Sender must be verified in Brevo → Senders & IP
EMAIL_FROM=Learning Tracker <teja26kt@gmail.com>

# Set OTP_MOCK=true locally to print login codes in the server terminal (no email sent)
OTP_MOCK=true

REMINDER_TIMEZONE=Asia/Kolkata
CRON_SECRET=your-long-random-cron-secret

FRONTEND_URL=https://learning-tracker-two-xi.vercel.app

ADMIN_EMAIL=teja26kt@gmail.com
