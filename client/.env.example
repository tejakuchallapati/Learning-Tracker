# Optional for local dev — npm run dev proxies /api to localhost:5001 automatically.
# Copy to .env.local only if you need overrides (e.g. Google OAuth).
#
# Required on Vercel (Project Settings → Environment Variables):
VITE_API_BASE_URL=https://learning-tracker-ko02.onrender.com/api
VITE_GOOGLE_CLIENT_ID=your-id-here.apps.googleusercontent.com

# Optional: Google Analytics 4 measurement ID (Vercel → Environment Variables)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: YouTube video ID for /walkthrough page (e.g. dQw4w9WgXcQ from youtube.com/watch?v=...)
# Leave empty to show the built-in interactive walkthrough instead.
# VITE_DEMO_VIDEO_YOUTUBE_ID=
